{
  "_comment": "Single source of truth for every package the Ricelin rice needs. Read by the installer and by the in-app updater. names[family] is the native package name on that distro family, or null when there is no native package and a fallback handler has to get it. aur=true means the Arch name lives in the AUR and needs a helper. repo carries an extra repo to enable first (copr: on Fedora, obs: on openSUSE). A package with a null name and a null fallback is provided by another package on that family and is simply skipped there.",
  "families": ["arch", "debian", "fedora", "suse"],
  "fallbacks": {
    "cargo": "cargo install, or a prebuilt release binary",
    "ghostty": "Zig source build or a third-party repo",
    "dotool": "Go source build plus a uinput udev rule and group",
    "nerdfont": "download the patched font from nerd-fonts releases and run fc-cache",
    "github": "download a release from the project's github",
    "flatpak": "install from Flathub",
    "curl": "the project's own curl-pipe installer"
  },
  "packages": [
    { "id": "hyprland", "group": "core", "required": true, "desc": "The Wayland compositor the whole rice runs on", "aur": false,
      "names": { "arch": "hyprland", "debian": "hyprland", "fedora": "hyprland", "suse": "hyprland" },
      "note": "repo hyprland 0.55+ ships the native lua config the rice uses (require/hyprland.lua), so the stable binary is enough and no AUR build is needed",
      "repo": { "fedora": "copr:solopasha/hyprland" }, "fallback": null },

    { "id": "quickshell", "group": "core", "required": true, "desc": "The QtQuick shell that draws the pill", "aur": false,
      "names": { "arch": "quickshell", "debian": "quickshell", "fedora": "quickshell", "suse": "quickshell" },
      "repo": { "suse": "obs:home:AvengeMedia:danklinux" }, "fallback": null },

    { "id": "matugen", "group": "core", "required": true, "desc": "Builds the color palette from your wallpaper", "aur": false,
      "names": { "arch": "matugen", "debian": null, "fedora": "matugen", "suse": null },
      "repo": { "fedora": "copr:heus-sueh/packages" }, "fallback": "cargo" },

    { "id": "swww", "group": "core", "required": true, "desc": "The wallpaper daemon", "aur": false,
      "names": { "arch": "swww", "debian": null, "fedora": "swww", "suse": "swww" },
      "note": "one arch name covers the whole family: on CachyOS pacman -S swww resolves to awww, which declares Provides: swww and Replaces: swww, while vanilla Arch installs native swww. The rice scripts call the awww binary, so a runtime symlink bridges awww->swww (or the reverse) after install; there is no swww crate on crates.io, so the cargo fallback builds from the LGFae/swww source",
      "repo": { "fedora": "copr:agonie/swww" }, "fallback": "cargo" },

    { "id": "hyprpicker", "group": "core", "required": true, "desc": "Picks a color from anywhere on screen", "aur": false,
      "names": { "arch": "hyprpicker", "debian": "hyprpicker", "fedora": "hyprpicker", "suse": "hyprpicker" },
      "repo": { "fedora": "copr:solopasha/hyprland" }, "fallback": null },

    { "id": "hyprpolkitagent", "group": "core", "required": true, "desc": "Pops the password prompt when something needs root", "aur": false,
      "names": { "arch": "hyprpolkitagent", "debian": "hyprpolkitagent", "fedora": "hyprpolkitagent", "suse": "hyprpolkitagent" },
      "repo": { "fedora": "copr:solopasha/hyprland" }, "fallback": null },

    { "id": "hypridle", "group": "core", "required": true, "desc": "Dims the screen and locks on idle", "aur": false,
      "names": { "arch": "hypridle", "debian": "hypridle", "fedora": "hypridle", "suse": "hypridle" },
      "repo": { "fedora": "copr:solopasha/hyprland" }, "fallback": null },

